# Copyrighted references kept locally only (not redistributable in a public repo).
# Only open-license documents are tracked: BOE legal texts (no IP per art. 13 LPI)
# and the CC BY Oumano 2025 JACMP article. See references/icrp107/README.md for
# how to obtain and verify the local-only files.
references/ICRP 119*.pdf
references/Art*culo*.pdf
references/Zanzonico*.pdf
references/icrp107/USERGUIDE.pdf

# ICRP 107 raw distribution files (© ICRP, "all rights reserved") — local only.
# Download free from icrp.org and verify SHA256 against data/icrp107-index.json.
data/sources/

# Local audit working reports (the remediation plan remains versioned in docs/).
docs/AUDIT_*.md

# Local working copy of the acceptance sheet (partially filled evidence).
# The tracked docs/ACCEPTANCE_TEST.md must stay a clean template.
docs/ACCEPTANCE_TEST.local.md

# Distribution staging and archives (built by tools/build-package.js)
dist/
